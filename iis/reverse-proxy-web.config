<?xml version="1.0" encoding="utf-8"?>
<!--
  Public IIS site: place as web.config (or merge). See iis/SETUP.txt.

  Prerequisites: URL Rewrite, ARR, server proxy enabled on the SERVER in IIS;
  then run iis/enable-rewrite-server-variables.ps1 (Administrator).

  Backend: default http://127.0.0.1:5000 — change both Rewrite urls if your port differs.
-->
<configuration>
  <system.webServer>
    <!--
      Enable ARR reverse proxy in IIS: Server (root) node -> Application Request Routing
      Cache -> Server Proxy Settings -> "Enable proxy" = true. (Do not duplicate invalid
      applicationRequestRouting in site config on some servers — use server UI.)
    -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="31457280" />
      </requestFiltering>
    </security>
    <rewrite>
      <allowedServerVariables>
        <add name="HTTP_X_FORWARDED_HOST" />
        <add name="HTTP_X_FORWARDED_PROTO" />
        <add name="HTTP_X_FORWARDED_FOR" />
      </allowedServerVariables>
      <rules>
        <rule name="NextJsProxyHttps" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="^on$" ignoreCase="true" />
          </conditions>
          <action type="Rewrite" url="http://127.0.0.1:5000/{R:1}" appendQueryString="true" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
            <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
          </serverVariables>
        </rule>
        <rule name="NextJsProxyHttp" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:5000/{R:1}" appendQueryString="true" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
            <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
