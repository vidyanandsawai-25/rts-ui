# Shared configuration for all environments
# These are defaults that can be overridden by .env.local
# Copy this file to .env.local and modify values for your local setup
 
# RUNTIME variables - read at server startup, not embedded at build time
RUNTIME_API_BASE_URL=https://localhost:44346/api
RUNTIME_APP_ENV=development
RUNTIME_FEATURE_ANALYTICS=false
RUNTIME_FEATURE_DEBUG=true
RUNTIME_AUTH_ENABLED=false
 