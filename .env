# # Shared configuration for all environments
# # These are defaults that can be overridden by .env.local
# # Copy this file to .env.local and modify values for your local setup

# # App Configuration
# APP_NAME=NTIS UI
# APP_VERSION=1.0.0.0

# # NTIS UI environment variables template
# # Fill in values for your environment or deployment.

# NEXT_PUBLIC_API_BASE_URL=https://localhost:7293/api
# NEXT_PUBLIC_APP_ENV=
# NEXT_PUBLIC_FEATURE_ANALYTICS=
# NEXT_PUBLIC_FEATURE_DEBUG=
# NEXT_PUBLIC_AUTH_ENABLED=
# NODE_TLS_REJECT_UNAUTHORIZED=0


# NTIS-UI Production Environment Configuration
# Tenant: Sample Municipal Corporation

NODE_ENV=production
PORT=5000

# API Configuration
NEXT_PUBLIC_API_BASE_URL=https://ptisapi.scipl.info.in/api
NEXT_PUBLIC_API_VERSION=v1

# Application Configuration
NEXT_PUBLIC_APP_NAME=NTIS Platform
NEXT_PUBLIC_APP_ENVIRONMENT=production

# Internationalization
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,hi,mr

# Security Configuration
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DEBUG=false
NODE_TLS_REJECT_UNAUTHORIZED=0
# Performance
NEXT_PUBLIC_ENABLE_SW=true

# SMS Gateway Configuration
SMS_GATEWAY_URL=http://sms.ptaxcollection.com/sendsms.jsp
SMS_USER=payakl
SMS_PASSWORD=fb05b4a701XX
SMS_SENDERID=AKOLMC
SMS_TEMPID=1707175319753583565

# Set to true to send actual SMS OTPs via gateway, or false to use 123456
NEXT_PUBLIC_LIVE_OTP=false

